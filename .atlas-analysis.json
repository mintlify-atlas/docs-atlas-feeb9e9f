  "keyFeatures": [
    "MVC architecture with routing, controllers, and view templating",
    "Eloquent-inspired ORM with HasOne, HasMany, and ManyToMany relations",
    "Database migrations and seeders system",
    "Session-based and API token authentication with PAM support",
    "Middleware pipeline for route protection",
    "CLI manager for scaffolding controllers, models, migrations, and more",
    "Built-in HTTP client (Guzzle-backed) for outbound requests",
    "WebSocket server for real-time features",
    "Form validation with custom rules",
    "SCSS compilation support",
    "File storage and QR code generation utilities"
  ],
  "publicApiSurface": [
    "Route::get / post / put / delete",
    "Route::middleware()",
    "Route::group()",
    "Route::name()",
