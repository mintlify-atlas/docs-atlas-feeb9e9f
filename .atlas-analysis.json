    "DB::transation()",
    "Schema::table()",
    "Schema::tableIfNotExists()",
    "Schema::dropIfExists()",
    "Auth::instance()",
    "HTTP::get / post / put / delete",
    "Request::input / get / post / put / all",
    "Manager::command()",
    "Manager::call()"
  ]
